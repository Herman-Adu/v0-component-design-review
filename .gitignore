/node_modules
/.next/
/out/
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# transient artifacts
/backups/
*-migration-report.json
*-verification-report.json
test-results.txt
postman-*.instructions.md
scripts/phase10-*.js