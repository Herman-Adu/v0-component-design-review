{
  "collectionName": "components_management_notice_blocks",
  "info": {
    "displayName": "Notice Block",
    "description": "Callout-style notice: warning, info, success, error"
  },
  "options": {},
  "attributes": {
    "icon": {
      "type": "string",
      "required": false
    },
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "noticeType": {
      "type": "enumeration",
      "enum": ["warning", "info", "success", "error"],
      "required": false,
      "default": "info"
    }
  }
}
