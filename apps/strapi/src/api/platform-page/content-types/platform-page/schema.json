{
  "kind": "collectionType",
  "collectionName": "platform_pages",
  "info": {
    "singularName": "platform-page",
    "pluralName": "platform-pages",
    "displayName": "Platform Page",
    "description": "Landing pages for digital marketing platforms (Google, Facebook, LinkedIn, Twitter)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "platform": {
      "type": "enumeration",
      "enum": ["google", "facebook", "linkedin", "twitter"],
      "required": true,
      "unique": true
    },
    "header": {
      "type": "component",
      "repeatable": false,
      "component": "admin.section-header",
      "required": true
    },
    "introTitle": {
      "type": "string",
      "required": false
    },
    "introText": {
      "type": "text",
      "required": false
    },
    "ecosystemPhases": {
      "type": "component",
      "repeatable": true,
      "component": "admin.ecosystem-phase",
      "required": false
    },
    "tools": {
      "type": "component",
      "repeatable": true,
      "component": "admin.tool-item",
      "required": false
    }
  }
}
