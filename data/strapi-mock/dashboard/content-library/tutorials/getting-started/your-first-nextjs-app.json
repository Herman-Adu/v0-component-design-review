      "type": "atom.paragraph",
      "atomicLevel": "atom",
      "props": {
        "text": "Start by creating a new Next.js 16 project using the create-next-app CLI."
      }
    },
    {
      "type": "molecule.codeBlock",
      "atomicLevel": "molecule",
      "props": {
        "code": "# Open your terminal and run:\nnpx create-next-app@latest my-first-app\n\n# When prompted, select:\n# - TypeScript: Yes\n# - ESLint: Yes\n# - Tailwind CSS: Yes\n# - src/ directory: No\n# - App Router: Yes\n# - Import alias: @/*",
        "language": "bash",
        "filename": null
      }
    },
    {
      "type": "molecule.infoBox",
      "atomicLevel": "molecule",
      "props": {
        "variant": "tip",
        "title": "💡 Hint",
        "body": "Make sure you have Node.js 18+ installed. Check with: node --version"
      }
    },
    {
      "type": "molecule.sectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "number": "02",
        "title": "Understanding the File Structure",
        "id": "step-2"
      }
    },
    {
      "type": "atom.paragraph",
      "atomicLevel": "atom",
      "props": {
        "text": "Next.js App Router uses a file-based routing system. Let's explore what was created."
      }
    },
    {
      "type": "molecule.subSectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "title": "✅ Solution",
        "id": "step-2-solution"
      }
    },
    {
      "type": "molecule.codeBlock",
      "atomicLevel": "molecule",
      "props": {
        "code": "my-first-app/\n├── app/\n│   ├── layout.tsx      # Root layout (wraps all pages)\n│   ├── page.tsx        # Homepage (/)\n│   └── globals.css     # Global styles\n├── public/             # Static files (images, etc.)\n├── next.config.mjs     # Next.js configuration\n├── tailwind.config.ts  # Tailwind configuration\n└── package.json        # Dependencies",
        "language": "text",
        "filename": null
      }
    },
    {
      "type": "molecule.infoBox",
      "atomicLevel": "molecule",
      "props": {
        "variant": "info",
        "title": "📖 Explanation",
        "body": "The app/ folder is where all your pages live. Each folder becomes a URL route, and page.tsx is what gets rendered."
      }
    },
    {
      "type": "molecule.sectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "number": "03",
        "title": "Building Your First Page",
        "id": "step-3"
      }
    },
    {
      "type": "atom.paragraph",
      "atomicLevel": "atom",
      "props": {
        "text": "Replace the default homepage with a simple contact page."
      }
    },
    {
      "type": "molecule.subSectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "title": "✅ Solution",
        "id": "step-3-solution"
      }
    },
    {
      "type": "molecule.codeBlock",
      "atomicLevel": "molecule",
      "props": {
        "code": "// app/page.tsx\nexport default function HomePage() {\n  return (\n    <main className=\"min-h-screen flex items-center justify-center bg-gray-50\">\n      <div className=\"max-w-md w-full p-8 bg-white rounded-xl shadow-lg\">\n        <h1 className=\"text-2xl font-bold text-gray-900 mb-6\">\n          Contact Us\n        </h1>\n        <form className=\"space-y-4\">\n          <div>\n            <label \n              htmlFor=\"name\" \n              className=\"block text-sm font-medium text-gray-700 mb-1\"\n            >\n              Name\n            </label>\n            <input\n              type=\"text\"\n              id=\"name\"\n              name=\"name\"\n              className=\"w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500\"\n              placeholder=\"Your name\"\n            />\n          </div>\n          <div>\n            <label \n              htmlFor=\"email\" \n              className=\"block text-sm font-medium text-gray-700 mb-1\"\n            >\n              Email\n            </label>\n            <input\n              type=\"email\"\n              id=\"email\"\n              name=\"email\"\n              className=\"w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500\"\n              placeholder=\"you@example.com\"\n            />\n          </div>\n          <button\n            type=\"submit\"\n            className=\"w-full py-2 px-4 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors\"\n          >\n            Send Message\n          </button>\n        </form>\n      </div>\n    </main>\n  )\n}",
        "language": "typescript",
        "filename": null
      }
    },
    {
      "type": "molecule.infoBox",
      "atomicLevel": "molecule",
      "props": {
        "variant": "info",
        "title": "📖 Explanation",
        "body": "This creates a styled contact form using Tailwind CSS classes. The form doesn't submit yet - we'll add that functionality next."
      }
    },
    {
      "type": "molecule.sectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "number": "04",
        "title": "Running Your Application",
