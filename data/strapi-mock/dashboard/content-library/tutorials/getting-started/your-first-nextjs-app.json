        "language": "bash",
        "filename": null
      }
    },
    {
      "type": "molecule.infoBox",
      "atomicLevel": "molecule",
      "props": {
        "variant": "tip",
        "title": "💡 Hint",
        "body": "The development server supports hot reload - changes you make will appear instantly without refreshing."
      }
    },
    {
      "type": "molecule.sectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "number": "05",
        "title": "Adding a Server Action",
        "id": "step-5"
      }
    },
    {
      "type": "atom.paragraph",
      "atomicLevel": "atom",
      "props": {
        "text": "Create a server action to handle form submissions securely."
      }
    },
    {
      "type": "molecule.subSectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "title": "✅ Solution",
        "id": "step-5-solution"
      }
    },
    {
      "type": "molecule.codeBlock",
      "atomicLevel": "molecule",
      "props": {
        "code": "// app/actions.ts\n\"use server\"\n\nexport async function submitContact(formData: FormData) {\n  const name = formData.get(\"name\") as string\n  const email = formData.get(\"email\") as string\n  \n  // Validate\n  if (!name || !email) {\n    return { success: false, error: \"All fields are required\" }\n  }\n  \n  // In production, you'd save to a database here\n  console.log(\"Contact submission:\", { name, email })\n  \n  return { success: true, message: \"Thanks for contacting us!\" }\n}",
        "language": "typescript",
        "filename": null
      }
    },
    {
      "type": "molecule.infoBox",
      "atomicLevel": "molecule",
      "props": {
        "variant": "info",
        "title": "📖 Explanation",
        "body": "Server Actions run on the server, keeping your data handling secure. The 'use server' directive marks this as server-only code."
      }
    }
  ]
