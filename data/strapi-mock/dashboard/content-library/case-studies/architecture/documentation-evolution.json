    {
      "type": "atom.paragraph",
      "atomicLevel": "atom",
      "props": {
        "text": "Technical documentation was scattered across README files, Notion pages, and Slack threads. New team members spent days searching for answers. Decision makers had no access to technical rationale. Knowledge left when developers left."
      }
    },
