    {
      "type": "molecule.sectionHeader",
      "atomicLevel": "molecule",
      "props": { "number": "06", "title": "Key Takeaway", "id": "takeaway" }
    },
    {
      "type": "molecule.keyTakeaway",
      "atomicLevel": "molecule",
      "props": {
        "text": "Documentation is a product, not an afterthought. Treating it with the same rigor as application code—structured data, shared components, skill-level targeting—transforms scattered notes into a competitive advantage. Store docs in version control. Build them with the same tech stack. Maintain them with the same discipline. The result: a living knowledge base that scales with your team."
      }
    }
