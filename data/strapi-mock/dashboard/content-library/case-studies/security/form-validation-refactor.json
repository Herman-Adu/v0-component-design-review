    {
      "type": "molecule.sectionHeader",
      "atomicLevel": "molecule",
      "props": { "number": "01", "title": "Context", "id": "context" }
    },
    {
      "type": "atom.paragraph",
      "atomicLevel": "atom",
      "props": {
        "text": "Our contact forms, multi-step registration flows, and data input pages relied entirely on client-side validation. This meant users got instant feedback, but security relied on trust - anyone could bypass validation with browser dev tools or curl requests."
      }
    },
    {
      "type": "molecule.sectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "number": "02",
        "title": "Problem Analysis",
        "id": "problem-analysis"
      }
    },
    {
      "type": "atom.paragraph",
      "atomicLevel": "atom",
      "props": {
        "text": "Our forms relied entirely on client-side validation, creating security vulnerabilities. Without server validation, we couldn't prevent invalid data from being processed."
      }
    },
    {
      "type": "organism.metricsGrid",
      "atomicLevel": "organism",
      "props": {
        "metrics": [
          {
