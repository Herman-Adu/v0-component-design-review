            "value": "None",
            "change": "Vulnerable",
            "positive": false
          },
          {
            "label": "Type Safety",
            "value": "Partial",
            "change": "Client only",
            "positive": false
          }
        ]
      }
    },
    {
      "type": "molecule.sectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "number": "03",
        "title": "Solution Approach",
        "id": "solution-approach"
      }
    },
    {
      "type": "atom.paragraph",
      "atomicLevel": "atom",
      "props": {
        "text": "We implemented dual-layer validation with shared Zod schemas. Client-side validation provides UX polish, server-side validation provides security. Input sanitization happens on both layers."
      }
    },
    {
      "type": "molecule.sectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "number": "04",
        "title": "Implementation",
        "id": "implementation"
      }
    },
    {
      "type": "organism.beforeAfterComparison",
      "atomicLevel": "organism",
      "props": {
        "beforeTitle": "Before: Client-Only Validation",
        "beforeCode": "// Client-only validation\nconst onSubmit = (data) => {\n  // Direct submission without server validation\n  await fetch('/api/submit', {\n    body: JSON.stringify(data)\n  })\n}",
        "afterTitle": "After: Dual-Layer Validation",
        "afterCode": "\"use server\"\n\nexport async function submitForm(data: unknown) {\n  // 1. Sanitize inputs\n  const sanitized = sanitizeFormData(data)\n  \n  // 2. Validate with Zod\n  const result = schema.safeParse(sanitized)\n  \n  // 3. Return type-safe errors\n  if (!result.success) {\n    return { success: false, errors: result.error }\n  }\n  \n  // 4. Process validated data\n  return processSubmission(result.data)\n}",
        "improvements": [
          { "metric": "Security Coverage", "before": "50%", "after": "100%" },
          {
            "metric": "Validation Consistency",
            "before": "Client only",
            "after": "Both layers"
          },
          { "metric": "Type Safety", "before": "Partial", "after": "Full" },
          { "metric": "XSS Prevention", "before": "None", "after": "Protected" }
        ]
      }
    },
    {
      "type": "molecule.codeBlock",
      "atomicLevel": "molecule",
      "props": {
        "filename": "lib/schemas/contact-schema.ts",
        "language": "typescript",
        "code": "import { z } from \"zod\"\n\nexport const contactSchema = z.object({\n  name: z.string().min(2).max(100),\n  email: z.string().email(),\n  message: z.string().min(10).max(5000),\n  phone: z.string().optional(),\n})\n\nexport type ContactForm = z.infer<typeof contactSchema>"
      }
    },
