            "positive": true
          },
          {
            "label": "Brand Consistency",
            "value": "+40%",
            "change": "60% → 100%",
            "positive": true
          }
        ]
      }
    },
    {
      "type": "molecule.infoBox",
      "atomicLevel": "molecule",
      "props": {
        "variant": "success",
        "title": "Editor Productivity Impact",
        "body": "Regional editors can now reuse global content with one click. Brand updates publish to all 12 sites simultaneously (previously 48 hours). Translation workflow integrated into single CMS (previously external). Content preview shows all 12 sites side-by-side for consistency checks."
      }
    },
    {
      "type": "molecule.sectionHeader",
      "atomicLevel": "molecule",
      "props": { "number": "06", "title": "Key Takeaway", "id": "takeaway" }
    },
    {
      "type": "molecule.keyTakeaway",
      "atomicLevel": "molecule",
      "props": {
        "text": "Multi-tenancy in Strapi scales content management without scaling complexity. The key is designing a content inheritance model that balances global consistency with local flexibility. Don't treat each site as a separate entity—model the relationships between global, regional, and local content from the start. The consolidation pays for itself in reduced licensing costs alone, but the real win is editorial velocity and brand consistency."
      }
    }
  ]
}
