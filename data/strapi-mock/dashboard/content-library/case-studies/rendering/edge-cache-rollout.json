  "blocks": [
    {
      "type": "molecule.sectionHeader",
      "atomicLevel": "molecule",
      "props": { "number": "01", "title": "Context", "id": "context" }
    },
    {
      "type": "atom.paragraph",
      "atomicLevel": "atom",
      "props": {
        "text": "International users experienced slow initial loads because pages were generated in a single region. We needed a way to serve cached HTML closer to users without giving up dynamic personalization."
      }
    },
    {
      "type": "molecule.infoBox",
      "atomicLevel": "molecule",
      "props": {
        "variant": "tip",
        "title": "Edge Wins",
        "body": "Edge caching can reduce latency by 40–70% for global traffic when applied to stable content."
      }
    },
    {
      "type": "molecule.sectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "number": "02",
        "title": "Problem Analysis",
        "id": "problem-analysis"
      }
    },
    {
      "type": "atom.paragraph",
      "atomicLevel": "atom",
      "props": {
        "text": "TTFB exceeded 900ms for APAC users and cache headers were inconsistent. We also had mixed content: some pages could be cached safely, others required personalization."
      }
    },
    {
      "type": "organism.metricsGrid",
      "atomicLevel": "organism",
      "props": {
        "metrics": [
          {
            "label": "APAC TTFB",
            "value": "920ms",
            "change": "Too slow",
            "positive": false
          },
          {
            "label": "Cache Hit Rate",
            "value": "18%",
            "change": "Low",
            "positive": false
          },
          {
            "label": "Edge Coverage",
            "value": "0",
            "change": "No edge cache",
            "positive": false
          },
          {
            "label": "Personalized Pages",
            "value": "35%",
            "change": "Mixed cacheability",
            "positive": false
          }
        ]
      }
    },
    {
      "type": "molecule.sectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "number": "03",
        "title": "Solution Approach",
        "id": "solution-approach"
      }
    },
    {
      "type": "atom.paragraph",
      "atomicLevel": "atom",
      "props": {
        "text": "We categorized routes by cacheability, added explicit revalidation windows, and deployed edge caching only for stable content. Personalized routes stayed on origin with server rendering."
      }
    },
    {
      "type": "organism.architectureDiagram",
      "atomicLevel": "organism",
