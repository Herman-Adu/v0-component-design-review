      "type": "molecule.codeBlock",
      "atomicLevel": "molecule",
      "props": {
        "filename": "Before: No Sanitization",
        "code": "// Direct user input to database\nawait db.insert({\n  name: formData.name,\n  email: formData.email,\n  message: formData.message,\n})"
      }
    },
    {
      "type": "molecule.codeBlock",
      "atomicLevel": "molecule",
      "props": {
        "filename": "After: Defense in Depth",
        "code": "// Security pipeline\nconst sanitized = sanitizeFormData(formData)\nconst validated = schema.parse(sanitized)\nconst safe = {\n  name: escapeHtml(validated.name),\n  email: validated.email.toLowerCase(),\n  message: escapeHtml(validated.message),\n}\nawait db.insert(safe)"
      }
    },
