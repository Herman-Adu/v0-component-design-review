        "title": "Validation Refactoring",
        "id": null
      }
    },
    {
      "type": "molecule.codeBlock",
      "atomicLevel": "molecule",
      "props": {
        "filename": "Before: Inline Validation",
        "code": "// Scattered across components\nif (!email || !email.includes('@')) {\n  setErrors({ email: 'Invalid email' })\n}\nif (!phone || phone.length < 10) {\n  setErrors({ phone: 'Invalid phone' })\n}\n// Repeated in multiple places..."
      }
    },
    {
      "type": "molecule.codeBlock",
      "atomicLevel": "molecule",
      "props": {
        "filename": "After: Centralized Zod Schemas",
        "code": "// lib/validation/schemas.ts\nexport const personalInfoSchema = z.object({\n  email: z.string()\n    .email('Please enter a valid email')\n    .transform(sanitizeEmail),\n  phone: z.string()\n    .regex(phoneRegex, 'Please enter a valid UK phone number')\n    .transform(sanitizePhone),\n})\n\n// Usage in components\nconst result = personalInfoSchema.safeParse(data)\nif (!result.success) {\n  return formatZodErrors(result.error)\n}"
      }
    },
    {
      "type": "organism.statsTable",
      "atomicLevel": "organism",
      "props": {
        "title": "Validation Refactoring Impact",
        "headers": ["Metric", "Before", "After"],
        "rows": [
          ["Validation code", "200 lines scattered", "50 lines centralized"],
          ["Consistency", "Varies by component", "100% consistent"],
          ["Type safety", "None", "Full TypeScript inference"]
        ]
      }
    },
