        "number": "01",
        "title": "Why Refactor?",
        "id": "why-refactor"
      }
    },
    {
      "type": "molecule.infoBox",
      "atomicLevel": "molecule",
      "props": {
        "variant": "info",
        "title": "The Refactoring Mindset",
        "body": "Refactoring is not about fixing bugs or adding features. It's about improving the internal structure of code without changing its external behavior. Think of it as cleaning and organizing while the house still functions perfectly."
      }
    },
    {
      "type": "atom.paragraph",
      "atomicLevel": "atom",
      "props": {
        "text": "In our electrical services form project, we continuously refactored to maintain code quality as requirements evolved. What started as a simple contact form grew into a sophisticated multi-step wizard with state management, validation, and email notifications."
      }
    },
    {
      "type": "organism.featureGrid",
      "atomicLevel": "organism",
      "props": {
        "columns": 2,
        "features": [
          {
            "icon": "zap",
            "title": "Improved Performance",
            "description": "Optimized renders, reduced bundle size, faster load times"
          },
          {
            "icon": "shield",
            "title": "Better Security",
            "description": "Centralized sanitization, type-safe validation, secure patterns"
          },
          {
            "icon": "code",
            "title": "Maintainability",
            "description": "Clear separation of concerns, reusable components, consistent patterns"
          },
          {
            "icon": "users",
            "title": "Team Productivity",
            "description": "Easier onboarding, predictable code locations, self-documenting architecture"
          }
        ]
      }
    },
    {
      "type": "molecule.sectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "number": "02",
        "title": "Recognizing Code Smells",
        "id": "code-smells"
      }
    },
    {
      "type": "atom.paragraph",
      "atomicLevel": "atom",
      "props": {
        "text": "Code smells are indicators that something might be wrong with your code structure. Learning to recognize them is the first step to effective refactoring."
      }
    },
    {
      "type": "organism.comparisonCards",
      "atomicLevel": "organism",
      "props": {
        "idealTitle": "Healthy Code Indicators",
        "notIdealTitle": "Common Code Smells",
        "idealFor": [
          "Single responsibility components",
          "Centralized state management",
          "Shared validation schemas",
          "Clear separation of concerns",
          "Consistent naming conventions",
          "Configuration in dedicated files"
        ],
        "notIdealFor": [
          "Components over 300 lines",
          "Props drilling through 3+ levels",
          "Duplicate validation logic",
          "Mixed concerns in single file",
          "Inconsistent naming patterns",
          "Hardcoded values scattered everywhere"
        ]
      }
    },
    {
      "type": "molecule.sectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "number": "03",
        "title": "Refactoring Patterns",
        "id": "refactoring-patterns"
      }
    },
    {
      "type": "molecule.subSectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "title": "Pattern 1: Extract Component",
        "id": null
      }
    },
    {
      "type": "atom.paragraph",
      "atomicLevel": "atom",
      "props": {
        "text": "When a component grows too large, extract logical sections into smaller, focused components."
      }
    },
    {
      "type": "molecule.codeBlock",
      "atomicLevel": "molecule",
      "props": {
        "filename": "Before: Monolithic Form",
        "code": "// One massive 500-line component\nfunction ServiceRequestForm() {\n  const [step, setStep] = useState(1)\n  const [formData, setFormData] = useState({})\n  const [errors, setErrors] = useState({})\n  \n  // 50+ lines of validation logic\n  // 100+ lines of form handlers\n  // 300+ lines of JSX for all 5 steps\n  \n  return (\n    <form>\n      {step === 1 && (/* Personal info fields */)}\n      {step === 2 && (/* Service selection */)}\n      {step === 3 && (/* Property details */)}\n      {step === 4 && (/* Schedule */)}\n      {step === 5 && (/* Review */)}\n    </form>\n  )\n}"
      }
    },
    {
      "type": "molecule.codeBlock",
      "atomicLevel": "molecule",
      "props": {
        "filename": "After: Atomic Components",
        "code": "// Orchestrating component\nfunction ServiceRequestForm() {\n  const { currentStep } = useFormStore()\n  \n  return (\n    <FormProvider>\n      <ProgressIndicator />\n      <StepRenderer step={currentStep} />\n      <NavigationControls />\n    </FormProvider>\n  )\n}\n\n// Each step is its own focused component\n// PersonalInfoStep.tsx - 80 lines\n// ServiceSelectionStep.tsx - 100 lines\n// PropertyDetailsStep.tsx - 90 lines\n// ScheduleStep.tsx - 70 lines\n// ReviewStep.tsx - 120 lines"
      }
    },
    {
      "type": "organism.statsTable",
      "atomicLevel": "organism",
      "props": {
        "title": "Extract Component Improvements",
        "headers": ["Metric", "Before", "After"],
        "rows": [
          ["Lines per file", "500+", "< 120"],
          ["Test coverage", "30%", "85%"],
          ["Time to understand", "30 min", "5 min"]
        ]
      }
    },
    {
      "type": "molecule.subSectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "title": "Pattern 2: Centralize State",
        "id": null
      }
    },
    {
      "type": "organism.dataFlowDiagram",
      "atomicLevel": "organism",
      "props": {
        "title": "State Management Evolution",
        "nodes": [
          {
            "label": "Props Drilling",
            "description": "Pass state through every component",
            "icon": "gitBranch"
          },
          {
            "label": "React Context",
            "description": "Global but causes re-renders",
            "icon": "layers"
          },
          {
            "label": "Zustand Store",
            "description": "Selective subscriptions, persistence",
            "icon": "database"
          }
        ]
      }
    },
    {
      "type": "molecule.codeBlock",
      "atomicLevel": "molecule",
      "props": {
        "filename": "lib/store/use-form-store.ts",
        "code": "// Centralized state with Zustand\nexport const useFormStore = create<FormState>()(\n  persist(\n    (set, get) => ({\n      currentStep: 1,\n      formData: {},\n      \n      // Actions\n      setStep: (step) => set({ currentStep: step }),\n      updateFormData: (data) => set({ \n        formData: { ...get().formData, ...data } \n      }),\n      reset: () => set({ currentStep: 1, formData: {} }),\n      \n      // Computed\n      canProceed: () => validateStep(get().currentStep, get().formData),\n    }),\n    { name: 'service-form' }\n  )\n)"
      }
    },
    {
      "type": "molecule.subSectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "title": "Pattern 3: Extract Utilities",
        "id": null
      }
    },
