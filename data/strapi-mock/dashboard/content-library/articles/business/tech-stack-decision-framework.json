          {
            "label": "Final Decision",
            "sublabel": "Choose and document",
            "color": "green"
          }
        ]
      }
    },
    {
      "type": "molecule.infoBox",
      "atomicLevel": "molecule",
      "props": {
        "variant": "tip",
        "title": "Document Your Decisions",
        "body": "Create an Architecture Decision Record (ADR) for every significant technology choice. Future team members will thank you when they understand why decisions were made."
      }
    },
    {
      "type": "molecule.sectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "number": "06",
        "title": "Key Takeaway",
        "id": "key-takeaway"
      }
    },
    {
      "type": "molecule.keyTakeaway",
      "atomicLevel": "molecule",
      "props": {
        "body": "Technology decisions should be business decisions first. Use a structured framework to remove emotion and bias from the process. Score options objectively, validate with proof of concepts, and document your reasoning for future reference."
      }
    },
