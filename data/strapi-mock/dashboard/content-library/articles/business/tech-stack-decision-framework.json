      "props": {
        "number": "04",
        "title": "Red Flags to Watch",
        "id": "red-flags"
      }
    },
    {
      "type": "atom.paragraph",
      "atomicLevel": "atom",
      "props": {
        "text": "Not all technologies that score well on paper make good choices. Watch for these warning signs that may not appear in standard evaluations."
      }
    },
    {
      "type": "organism.featureGrid",
      "atomicLevel": "organism",
      "props": {
        "columns": 2,
        "features": [
          {
            "icon": "users",
            "title": "Single Maintainer",
            "description": "Projects dependent on one person are at risk of abandonment"
          },
          {
            "icon": "trendingUp",
            "title": "Declining Activity",
            "description": "Decreasing GitHub commits, stale issues, unanswered questions"
          },
          {
            "icon": "shield",
            "title": "No Governance Model",
            "description": "Unclear decision-making process, no roadmap, unclear ownership"
          },
          {
            "icon": "zap",
            "title": "Excessive Breaking Changes",
            "description": "Frequent major versions requiring significant migration effort"
          }
        ]
      }
    },
    {
      "type": "molecule.infoBox",
      "atomicLevel": "molecule",
      "props": {
        "variant": "warning",
        "title": "The Hype Trap",
        "body": "New technologies often have enthusiastic communities that overstate benefits and understate problems. Wait for production usage reports before adopting anything in the first year of release."
      }
    },
    {
      "type": "molecule.sectionHeader",
      "atomicLevel": "molecule",
      "props": {
        "number": "05",
