    {
      "type": "atom.paragraph",
      "atomicLevel": "atom",
      "props": {
        "text": "Technical debt accumulates silently, then suddenly becomes the primary driver of all development costs. Understanding where teams spend their time reveals the true cost of architectural decisions."
      }
