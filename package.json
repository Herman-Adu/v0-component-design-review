{
  "name": "@v0/monorepo",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev":          "pnpm --filter @v0/ui dev",
    "build":        "pnpm --filter @v0/ui build",
    "start":        "pnpm --filter @v0/ui start",
    "test":         "pnpm --filter @v0/ui test",
    "lint":         "pnpm --filter @v0/ui lint",
    "typecheck":    "pnpm --filter @v0/ui exec tsc --noEmit",
    "strapi:dev":   "pnpm --filter @v0/strapi develop",
    "strapi:build": "pnpm --filter @v0/strapi build",
    "dev:all":      "pnpm --parallel \"/^(dev|strapi:dev)$/\"",
    "prepare":      "husky"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  }
}
